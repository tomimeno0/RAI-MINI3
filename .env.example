# Clave compartida entre cliente y servidor para proteger los endpoints.
RAI_SERVER_API_KEY=pon-tu-api-key-aqui

# Ruta del archivo SQLite que guarda el catálogo de aplicaciones.
# Podés dejar el valor por defecto (ruta relativa dentro del repositorio)
# o cambiarlo por una ubicación absoluta, por ejemplo:
# DB_PATH=C:\\Users\\tu-usuario\\rai-mini\\apps.sqlite
DB_PATH=rai\\server\\apps.sqlite

# Orígenes permitidos para CORS. Separá múltiples entradas por comas.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Limitadores simples en memoria para evitar abusos accidentales.
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=20

# Host y puerto opcionales del servidor Flask.
RAI_SERVER_HOST=127.0.0.1
RAI_SERVER_PORT=5050

# URL que usa el cliente para enviar comandos (opcional, pero útil en dev).
RAI_SERVER_URL=http://127.0.0.1:5050/parse
